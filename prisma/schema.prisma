generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Product{
  id Int @id @default(autoincrement())
  name String
  price Decimal @default(0)
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

